{
  "name": "nuxt-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "vitest --browser.headless=false",
    "test:unit": "vitest run .unit.spec.ts",
    "coverage:unit": "vitest run .unit.spec.ts --coverage",
    "test:visual": "vitest run .visual.spec.ts",
    "lint": "eslint --ext .js,.vue src",
    "typecheck": "vue-tsc -p ./tsconfig.app.json",
    "msw:init": "msw init public/ --save"
  },
  "dependencies": {
    "@nuxt/ui": "4.6.1",
    "@tanstack/vue-query": "5.97.0",
    "@tanstack/vue-query-devtools": "6.1.14",
    "arktype": "2.2.0",
    "ofetch": "1.5.1",
    "pinia": "3.0.4",
    "tailwindcss": "4.2.2",
    "vue": "3.5.32",
    "vue-router": "5.0.4"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-query": "5.97.0",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/node": "25.5.2",
    "@vitejs/plugin-vue": "6.0.5",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "@vue/eslint-config-typescript": "14.7.0",
    "eslint": "10.2.0",
    "eslint-plugin-vue": "10.8.0",
    "msw": "2.13.2",
    "oxfmt": "^0.44.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vite": "8.0.8",
    "vite-bundle-analyzer": "1.3.7",
    "vitest": "4.1.4",
    "vitest-browser-vue": "2.1.0",
    "vue-tsc": "3.2.6"
  },
  "engines": {
    "node": "24.14.1",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
