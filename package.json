{
  "name": "nuxt-ui-example",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.0.3",
  "engines": {
    "node": "24.15.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "vite build",
    "coverage:unit": "vitest run .unit.spec.ts --coverage",
    "dev": "vite",
    "preinstall": "node ./scripts/check-npmrc.mjs --quiet",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "lint:npmrc": "node scripts/check-npmrc.mjs",
    "lint:package": "npmPkgJsonLint .",
    "msw:init": "msw init public/ --save",
    "preview": "vite preview",
    "test": "vitest --browser.headless=false",
    "test:unit": "vitest run .unit.spec.ts",
    "test:visual": "vitest run .visual.spec.ts",
    "type-check": "vue-tsc -p ./tsconfig.app.json"
  },
  "dependencies": {
    "@nuxt/ui": "4.7.1",
    "@tanstack/vue-query": "5.100.8",
    "@tanstack/vue-query-devtools": "6.1.27",
    "arktype": "2.2.0",
    "ofetch": "1.5.1",
    "pinia": "3.0.4",
    "tailwindcss": "4.2.4",
    "vue": "3.5.33",
    "vue-router": "5.0.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "8.2.0",
    "@tanstack/eslint-plugin-query": "5.100.8",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/node": "25.6.0",
    "@vitejs/plugin-vue": "6.0.6",
    "@vitest/browser-playwright": "4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "@vue/eslint-config-typescript": "14.7.0",
    "eslint": "10.3.0",
    "eslint-plugin-package-json": "0.91.2",
    "eslint-plugin-vue": "10.9.0",
    "msw": "2.14.2",
    "npm-package-json-lint": "10.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vite": "8.0.10",
    "vite-bundle-analyzer": "1.3.8",
    "vitest": "4.1.5",
    "vitest-browser-vue": "2.1.0",
    "vue-tsc": "3.2.7"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
